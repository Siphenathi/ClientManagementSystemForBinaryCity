@model ClientManagementSystem.Model.LinkClientsToContact
@{
    ViewData["Title"] = "Link Clients";
}

<h1 class="text-center">Link Clients to contact</h1>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ContactId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ContactId)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Surname)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Surname)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DateOfRecord)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DateOfRecord)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.NumberOfLinkedClient)
        </dt>
        <dd class="col-sm-10">
            @Model.Clients.Count(x => x.Linked)
        </dd>
    </dl>

    <form asp-action="LinkClients" method="post">
        @Html.HiddenFor(modelItem => modelItem.ContactId)
        <table class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>
                        @Html.DisplayName("Client Code")
                    </th>
                    <th>
                        @Html.DisplayName("Client Name")
                    </th>
                    <th>Link</th>
                </tr>
            </thead>
            <tbody>
                @for (var index = 0; index < Model.Clients.Count; index++)
                {
                    <tr>
                        <td class="text-left">
                            @Html.HiddenFor(m => m.Clients[index].ClientCode)
                            @Html.DisplayFor(m => m.Clients[index].ClientCode)
                        </td>
                        <td class="text-left">
                            @Html.DisplayFor(m => m.Clients[index].Name)
                        </td>
                        <td class="text-center">
                            @Html.EditorFor(m => m.Clients[index].Linked)
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="form-group text-center">
            <input type="submit" value="Update" class="btn btn-primary" />
        </div>
    </form>
    @if (ViewBag.FeedbackMsg != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.FeedbackMsg");
            };
        </script>
    }
</div>
<div>
    <a asp-action="AllContacts">Back to Clients</a>
</div>
