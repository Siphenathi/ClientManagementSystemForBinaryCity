@model ClientManagementSystem.Model.LinkContactsToClient
@{
    ViewData["Title"] = "Details";
}

<h1 class="text-center">Link Contacts to Client</h1>
<div>
    <hr />
    <dl class="row" >
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ClientCode)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ClientCode)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DateOfRecord)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DateOfRecord)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NumberOfLinkedContacts)
        </dt>
        <dd class = "col-sm-10">
            @Model.Contacts.Count(x => x.Linked)
        </dd>
    </dl>
    <form asp-action="LinkContacts" method="post">
        @Html.HiddenFor(modelItem => modelItem.ClientCode)
        <table class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
            <tr>
                <th>
                    @Html.DisplayName("Name")
                </th>
                <th>
                    @Html.DisplayName("Surname")
                </th>
                <th class="text-center">
                    @Html.DisplayName("Email")
                </th>
                <th>Link</th>
            </tr>
            </thead>
            <tbody>
            @for (var index = 0; index < Model.Contacts.Count; index++)
            {
                <tr>
                    <td class="text-left">
                        @Html.HiddenFor(m => m.Contacts[index].ContactId)
                        @Html.DisplayFor(m => m.Contacts[index].Name)
                    </td>
                    <td class="text-left">
                        @Html.DisplayFor(m => m.Contacts[index].Surname)
                    </td>
                    <td class="text-left">
                        @Html.DisplayFor(m => m.Contacts[index].Email)
                    </td>
                    <td class="text-center">
                        @Html.EditorFor(m => m.Contacts[index].Linked)
                    </td>
                </tr>
            }
            </tbody>
        </table>
        <div class="form-group text-center">
            <input type="submit" value="Update" class="btn btn-primary" />
        </div>
    </form>
    @if (ViewBag.FeedbackMsg != null)
    {
        <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.FeedbackMsg");
            };
        </script>
    }
</div>
<div>
    <a asp-action="AllClients">Back to Clients</a>
</div>
